<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.ssh-session-manager</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/manny/develop/git/development_env/scripts/ssh-session-manager/ssh-session-manager.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/manny/Library/Logs/ssh-session-manager.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/manny/Library/Logs/ssh-session-manager.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>SSH_CONFIG_DIR</key>
        <string>/Users/manny/.ssh/config.d</string>
        <key>SSH_HOSTS_PORT</key>
        <string>8822</string>
    </dict>
</dict>
</plist>
